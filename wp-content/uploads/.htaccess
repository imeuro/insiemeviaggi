# Protezione file customer-data.*
# Questi file contengono dati sensibili e devono essere accessibili solo tramite endpoint WordPress autenticati
# File generato automaticamente dal plugin LTC Custom

<FilesMatch "^(customer-data\.(json|csv|txt))$">
    Require all denied
    <IfModule !mod_authz_core.c>
        Order deny,allow
        Deny from all
    </IfModule>
</FilesMatch>
